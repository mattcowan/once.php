# Canonical host for generated share links.
# Prevents host-header injection by ignoring the HTTP Host header.
# Include scheme and host (no trailing slash).
# Example: https://notes.example.com
# If left empty, the app falls back to the HTTP Host header.
CANONICAL_HOST=

# Base64- or hex-encoded 32-byte encryption key for server-side notes.
# If left empty, a key is auto-generated and stored in private-notes/.secretkey.
PRIVATE_NOTES_KEY=
